# ================================================================
# Local development template — copy to `_env/local.env` and fill in.
#
# SECRET HYGIENE — READ BEFORE EDITING
# - Every non-empty value in this committed file MUST be a placeholder
#   (safe default, dummy host, or the literal word REPLACE_ME). Real
#   credentials go into `_env/local.env` only (gitignored).
# - `gitleaks` runs as a pre-commit hook and will block a commit that
#   contains a real access key. See ../SECURITY.md for the full policy.
# ================================================================

ENV=local
TASK_NAME_PREFIX=my-project

ADMIN_STORAGE_SECRET=change-me-in-production
ADMIN_BOOTSTRAP_ENABLED=true
ADMIN_BOOTSTRAP_USERNAME=admin
ADMIN_BOOTSTRAP_PASSWORD=REPLACE_ME
ADMIN_BOOTSTRAP_EMAIL=admin@example.com
ADMIN_BOOTSTRAP_FULL_NAME=Administrator

DATABASE_ENGINE=postgresql
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_HOST=127.0.0.1
DATABASE_PORT=5432
DATABASE_NAME=postgres
# DATABASE_POOL_SIZE=       (default: local/dev=5, stg/prod=10)
# DATABASE_MAX_OVERFLOW=    (default: local/dev=10, stg/prod=20)
# DATABASE_POOL_RECYCLE=    (default: 3600)
# DATABASE_ECHO=            (default: local/dev=true, stg/prod=false)

S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=ap-northeast-2
S3_BUCKET_NAME=bucket

MINIO_HOST=127.0.0.1
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=bucket

# ----------------------------------------------------------------
# Message Broker (sqs / rabbitmq / inmemory, default: inmemory)
# ----------------------------------------------------------------
# BROKER_TYPE=inmemory

# AWS SQS (required when BROKER_TYPE=sqs)
AWS_SQS_REGION=ap-northeast-2
AWS_SQS_ACCESS_KEY=
AWS_SQS_SECRET_KEY=
AWS_SQS_URL=

# RabbitMQ (required when BROKER_TYPE=rabbitmq)
# RABBITMQ_URL=amqp://guest:guest@localhost:5672/

DYNAMODB_REGION=ap-northeast-2
DYNAMODB_ACCESS_KEY=
DYNAMODB_SECRET_KEY=
DYNAMODB_ENDPOINT_URL=http://localhost:8000

# ----------------------------------------------------------------
# Embedding (openai / bedrock / google / ollama / sentence-transformers)
# Uses PydanticAI Embedder — dimension auto-derived from model
# ----------------------------------------------------------------
# EMBEDDING_PROVIDER=openai
# EMBEDDING_MODEL=                        (default: provider-specific, dimension auto-derived)

# OpenAI (required when EMBEDDING_PROVIDER=openai, or set OPENAI_API_KEY)
# EMBEDDING_OPENAI_API_KEY=

# Bedrock (per-service credentials, or uses AWS_* env vars as fallback)
# EMBEDDING_BEDROCK_ACCESS_KEY=
# EMBEDDING_BEDROCK_SECRET_KEY=
# EMBEDDING_BEDROCK_REGION=us-east-1

# Google (uses GOOGLE_API_KEY env var automatically)
# Ollama (default: http://localhost:11434, no auth needed)
# SentenceTransformers (local model, no auth needed)

# ----------------------------------------------------------------
# LLM (openai / anthropic / bedrock — required for PydanticAI agents)
# ----------------------------------------------------------------
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o
# LLM_API_KEY=

# Bedrock (required when LLM_PROVIDER=bedrock)
# LLM_BEDROCK_ACCESS_KEY=
# LLM_BEDROCK_SECRET_KEY=
# LLM_BEDROCK_REGION=us-east-1

# ----------------------------------------------------------------
# Observability (OpenTelemetry — optional, requires --extra otel)
# ----------------------------------------------------------------
# OTEL_ENABLED=true
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# (See docs/operations/observability-otel.md for Jaeger/Tempo/Phoenix recipes)

ALLOWED_HOSTS=["localhost","127.0.0.1"]
ALLOW_ORIGINS=["*"]
