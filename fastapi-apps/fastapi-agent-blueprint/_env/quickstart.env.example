# ================================================================
# Zero-config quickstart — run with `make quickstart`
#
# This env file is loaded automatically when you run `make quickstart`.
# The goal: spin up the blueprint in under 60 seconds with no external
# infrastructure (no Docker, no Postgres, no cloud credentials).
#
# Everything here uses safe local defaults:
#   - SQLite file-backed database (./quickstart.db)
#   - InMemory Taskiq broker (no queue needed)
#   - No storage / DynamoDB / S3 Vectors / Embedding / LLM
#   - Admin dashboard bootstraps admin/admin — CHANGE BEFORE ANY DEPLOYMENT
#
# For real local development, copy `_env/local.env.example` to
# `_env/local.env` and run `make dev` instead.
#
# SECRET HYGIENE: no value in this committed template is ever a real
# credential. Every placeholder is an obvious default (`admin`,
# `unused`, or a namespaced dummy string). Keep it that way — see
# ../SECURITY.md.
# ================================================================

ENV=quickstart

# ----------------------------------------------------------------
# Admin Dashboard — http://127.0.0.1:8001/admin
# ----------------------------------------------------------------
ADMIN_STORAGE_SECRET=quickstart-dev-only-do-not-deploy
ADMIN_BOOTSTRAP_ENABLED=true
ADMIN_BOOTSTRAP_USERNAME=admin
ADMIN_BOOTSTRAP_PASSWORD=admin
ADMIN_BOOTSTRAP_EMAIL=admin@example.com
ADMIN_BOOTSTRAP_FULL_NAME=Administrator

# ----------------------------------------------------------------
# Database — SQLite file (no server required)
# ----------------------------------------------------------------
DATABASE_ENGINE=sqlite
DATABASE_NAME=./quickstart.db

# sqlite ignores the fields below, but Settings still reads them
DATABASE_USER=unused
DATABASE_PASSWORD=unused
DATABASE_HOST=unused
DATABASE_PORT=0

# ----------------------------------------------------------------
# Message Broker — InMemory (no broker process required)
# ----------------------------------------------------------------
BROKER_TYPE=inmemory

# ----------------------------------------------------------------
# Vector Store — InMemory (process-local cosine search)
#   Switch to ``s3vectors`` + set S3VECTORS_* to persist across
#   restarts. Used by the RAG domain (see `make demo-rag`).
# ----------------------------------------------------------------
VECTOR_STORE_TYPE=inmemory

# ----------------------------------------------------------------
# RAG stubs — when EMBEDDING_PROVIDER / LLM_PROVIDER are unset,
#   the RAG domain falls back to stub providers:
#     - embedder : keyword bag-of-words, 128-dim (not semantic)
#     - LLM      : templated answer built from retrieved chunks
#   This lets `make demo-rag` run with zero AWS / OpenAI keys.
#   For real answers, set EMBEDDING_PROVIDER + LLM_PROVIDER below.
# ----------------------------------------------------------------
# EMBEDDING_PROVIDER=openai
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_OPENAI_API_KEY=sk-...
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini
# LLM_API_KEY=sk-...

# ----------------------------------------------------------------
# Network
# ----------------------------------------------------------------
ALLOWED_HOSTS=["localhost","127.0.0.1"]
ALLOW_ORIGINS=["*"]

# ----------------------------------------------------------------
# Logging (structlog + stdlib bridge, #9)
#   LOG_LEVEL        : DEBUG / INFO / WARNING / ERROR
#   LOG_JSON_FORMAT  : leave unset for ENV-derived default (dev → console,
#                      stg/prod → JSON). Set to true/false to override —
#                      useful for flipping console on in prod when
#                      debugging without a full config redeploy.
# ----------------------------------------------------------------
LOG_LEVEL=INFO
# LOG_JSON_FORMAT=false

# ----------------------------------------------------------------
# Observability (OpenTelemetry — optional, requires --extra otel)
#   OTEL_ENABLED defaults to false — quickstart works unchanged.
#   See docs/operations/observability-otel.md for recipes.
# ----------------------------------------------------------------
# OTEL_ENABLED=true
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
