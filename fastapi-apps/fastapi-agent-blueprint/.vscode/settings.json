        "**/.git/subtree-cache/**": true,
        "**/.venv/**": true,
        "**/__pycache__/**": true,
        "**/.mypy_cache/**": true,
        "**/.sisyphus/**": true,
        "**/uv.lock": true,
        "**/coverage.xml": true,
        "**/htmlcov/**": true
    },
    "search.exclude": {
        "**/.venv": true,
        "**/__pycache__": true,
        "**/.mypy_cache": true,
        "**/.sisyphus": true,
        "**/uv.lock": true,
        "**/coverage.xml": true,
        "**/htmlcov": true
    },
    "files.exclude": {
