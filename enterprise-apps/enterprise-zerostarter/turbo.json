{
  "$schema": "https://turborepo.com/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", ".source/**", "bundle/**", "dist/**"]
    },
    "build:vercel": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "vercel-bundle/**"]
    },
    "check-types": {
      "dependsOn": ["^build"]
    },
    "dev": {
      "dependsOn": ["^build"],
      "persistent": true,
      "cache": false
    },
    "start": {
      "persistent": true,
      "cache": false
    },
    "test": {
      "dependsOn": ["^build"]
    }
  },
  "globalDependencies": [".env*"],
  "globalEnv": [
    // CI variables
    "SKIP_ENV_VALIDATION",
    "SKIP_ENV_VALIDATION_SERVER",
    // Server variables
    "NODE_ENV",
    "BETTER_AUTH_SECRET",
    "GITHUB_CLIENT_ID",
    "GITHUB_CLIENT_SECRET",
    "GOOGLE_CLIENT_ID",
    "GOOGLE_CLIENT_SECRET",
    "HONO_APP_URL",
    "HONO_PORT",
    "HONO_RATE_LIMIT",
    "HONO_RATE_LIMIT_WINDOW_MS",
    "HONO_TRUSTED_ORIGINS",
    "HONO_WEB_URL",
    "INTERNAL_API_URL",
    "POSTGRES_URL",
    // Client variables
    "NEXT_PUBLIC_API_URL",
    "NEXT_PUBLIC_APP_URL",
    "NEXT_PUBLIC_POSTHOG_HOST",
    "NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN",
    "NEXT_PUBLIC_USERJOT_URL"
  ],
  "globalPassThroughEnv": ["PORTLESS", "PORTLESS_HTTPS", "PORTLESS_PORT", "PORTLESS_SYNC_HOSTS"]
}
